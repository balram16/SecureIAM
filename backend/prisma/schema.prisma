datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum PolicyType {
  MANAGED
  INLINE
}

model User {
  id           String                @id @default(uuid())
  name         String
  email        String                @unique
  passwordHash String
  isRoot       Boolean               @default(false)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  memberships  UserGroupMembership[]
  policies     UserPolicyAttachment[]
  boundary     UserBoundary?
  refreshToken String?

  @@map("users")
}

model Group {
  id          String                  @id @default(uuid())
  name        String                  @unique
  description String?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  memberships UserGroupMembership[]
  policies    GroupPolicyAttachment[]

  @@map("groups")
}

model Policy {
  id          String                    @id @default(uuid())
  name        String                    @unique
  description String?
  type        PolicyType
  statements  Json
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
  groups      GroupPolicyAttachment[]
  users       UserPolicyAttachment[]
  boundaries  UserBoundary[]

  @@map("policies")
}

model UserGroupMembership {
  userId  String
  groupId String
  addedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
  @@map("user_group_memberships")
}

model GroupPolicyAttachment {
  groupId    String
  policyId   String
  attachedAt DateTime @default(now())

  group  Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  policy Policy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@id([groupId, policyId])
  @@map("group_policy_attachments")
}

model UserPolicyAttachment {
  userId     String
  policyId   String
  attachedAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  policy Policy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@id([userId, policyId])
  @@map("user_policy_attachments")
}

model UserBoundary {
  userId   String   @id @unique
  policyId String
  setAt    DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  policy Policy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@map("user_boundaries")
}
